# Env file for the STAGING (local test) environment.
# Loaded automatically when NODE_ENV is NOT "production".
# The `dev` script (apps/bot/package.json) sets NODE_ENV=staging, so
# `pnpm --filter bot dev` on this machine reads this file.
# Copy this file to ".env.staging" and fill in the test app token.
# Never commit ".env.staging" (it contains a real token).

# Discord bot token of the TEST (staging) app from the Developer Portal. Required.
DISCORD_TOKEN=

# Path to the staging config.json. Kept separate from production's config.json
# so that running /pomo init in the test guild never overwrites production settings.
# Generated automatically by running /pomo init in your test guild.
CONFIG_PATH=./config.staging.json

# Log level: debug | info | warn | error (optional, default info)
LOG_LEVEL=info
