# 依存・ビルド成果物
node_modules/
dist/
*.tsbuildinfo

# ログ
*.log

# 環境変数 (DISCORD_TOKEN 等。絶対にコミットしない)
# .env (本番) / .env.staging (ローカルのテスト版app) はいずれも Token を含むためコミットしない。
.env
.env.staging
!.env.example
!.env.staging.example

# ランタイム生成設定 (/pomo init で生成される)
# guild ごとの設定は <config名>.guilds/<guildId>.json に保存される (複数サーバー対応)。
# 本番は config.guilds/、テストは config.staging.guilds/ に分離される。
# 旧単一 config.json / config.staging.json は起動時に自動移行され .migrated へ退避。
apps/bot/config.json
apps/bot/config.staging.json
apps/bot/config.json.migrated
apps/bot/config.staging.json.migrated
apps/bot/config.guilds/
apps/bot/config.staging.guilds/

# pidfile (多重起動防止。SIGKILL 等で残った場合は次回起動時に stale 判定で回収される)
bot.pid

# 音源ファイルはライセンス上リポジトリに含めない (再配布制限のため)。
# デプロイ時に apps/bot/assets/sounds/ へ手動配置する。詳細は同 LICENSE.md 参照。
apps/bot/assets/sounds/*.mp3
apps/bot/assets/sounds/*.ogg
